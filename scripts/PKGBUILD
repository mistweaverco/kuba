# Maintainer: mistweaverco <oss@mistweaverco.com>
pkgname=kuba-bin
pkgver=0.0.0 # CI will take care
pkgrel=1
pkgdesc="Get rid of .env files. Pass env directly from GCP, AWS, Azure, Bitwarden and OpenBao."
arch=('x86_64' 'i686' 'aarch64')
url="https://github.com/mistweaverco/kuba"
license=('MIT')
provides=('kuba')
conflicts=('kuba')
source_x86_64=("${pkgname}-${pkgver}.tar.gz::https://github.com/mistweaverco/kuba/releases/download/v${pkgver}/kuba-linux-amd64")
source_i686=("${pkgname}-${pkgver}.tar.gz::https://github.com/mistweaverco/kuba/releases/download/v${pkgver}/kuba-linux-386")

# NOTE: Auto-generated by CI via updpkgsums
sha256sums_x86_64=('AUTO_GENERATED')
sha256sums_i686=('AUTO_GENERATED')

package() {
    # NOTE: We rename the downloaded file to 'kuba' and put it in /usr/bin
    install -Dm755 "${srcdir}/${pkgname}-${pkgver}.tar.gz" "${pkgdir}/usr/bin/kuba"
    install -Dm644 "${srcdir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
